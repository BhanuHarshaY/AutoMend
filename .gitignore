# =============================================================================
# Model 2 Training — model weights and checkpoints
# =============================================================================

# Model weight files (too large for Git — use DVC or HuggingFace Hub)
*.safetensors
*.npz

# PyTorch optimizer / scheduler / RNG state files from checkpoints
*.pt
*.pth

# All training outputs — regeneratable by rerunning the pipeline
# (checkpoints, reports, predictions — all ignored to avoid conflicts)
model_2_training/outputs/

# W&B local run directories (large binary .wandb files + logs)
# Runs are already synced to wandb.ai — local copies are not needed in Git
model_2_training/wandb/
