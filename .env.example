# AutoMend MLOps Pipeline - Environment Variables
# ================================================
# Copy this file to .env and update values as needed

# =============================================================================
# DATA ACQUISITION MODE
# =============================================================================
# Controls how each pipeline acquires raw data when it is missing.
#   dummy  - Generate synthetic data offline (fast, no network, for E2E testing)
#   sample - Download a capped subset from the real source (network required)
#   full   - Download the full dataset (network + API tokens may be required)
PIPELINE_DATA_MODE=dummy

# =============================================================================
# SLACK ALERTING (Centralized)
# =============================================================================
# Webhook URL for Slack notifications
# Get this from Slack: Apps > Incoming Webhooks > Add to Slack > Choose channel
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: Channel name (for display purposes, webhook determines actual channel)
SLACK_CHANNEL=#automend-alerts

# =============================================================================
# DATASET 4: SYNTHETIC (Gemini API)
# =============================================================================
# Google Gemini API key for synthetic data generation
GOOGLE_API_KEY=your_google_api_key_here

# =============================================================================
# DATASET 6: THE STACK (Hugging Face)
# =============================================================================
# Hugging Face token for accessing The Stack dataset
# Only needed if downloading from HF Hub
HF_TOKEN=your_hugging_face_token_here

# =============================================================================
# WEIGHTS & BIASES (Experiment Tracking)
# =============================================================================
# Get your API key from: https://wandb.ai/settings (under "API keys")
# Shared by both Model 1 and Model 2 training pipelines.
WANDB_API_KEY=your_wandb_api_key_here

# Project name — Model 2 runs appear under this project on wandb.ai.
# Model 1 uses "automend-model1" (hardcoded in its Docker/GCP config).
WANDB_PROJECT=automend-model2

# Your W&B username or team name (visible in the URL: wandb.ai/<entity>/<project>)
WANDB_ENTITY=your_wandb_username_or_team

# Fix for W&B 0.25.x service process startup failure on Windows:
# Uses a thread instead of a subprocess so no port file handshake is needed.
WANDB_START_METHOD=thread

# =============================================================================
# DVC REMOTE (Production)
# =============================================================================
# For Google Cloud Storage remote (production)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# For AWS S3 remote
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
